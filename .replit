modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "HapticAI Dev Server"

[[workflows.workflow]]
name = "HapticAI Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/hapticai-server && HAPTICAI_HOST=0.0.0.0 python web_app.py"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 19003
externalPort = 5000

[[ports]]
localPort = 20002
externalPort = 3003

[[ports]]
localPort = 20441
externalPort = 3000

[[ports]]
localPort = 21559
externalPort = 5173

[[ports]]
localPort = 22885
externalPort = 3002

[[ports]]
localPort = 23998
externalPort = 4200

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_CLERK_PUBLISHABLE_KEY = "pk_test_dXNhYmxlLWdvYmJsZXItNjUuY2xlcmsuYWNjb3VudHMuZGV2JA"
STRIPE_PRICE_ID = "price_1TTEywLm1BrqnliEgrgiPMZx"
STRIPE_EARLY_BIRD_COUPON_ID = "HAPTICOS_EARLY_BIRD_50"
HAPTICAI_GITHUB_REPO = "BurnedByAcid/hapticai-server"
AISCRIPTER_GITHUB_REPO = "BurnedByAcid/haptic_os_AI_scripter"

[objectStorage]
defaultBucketID = "replit-objstore-8d0b8bc7-9fdc-457e-96d6-f363f2de9dff"
